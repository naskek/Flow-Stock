<Window x:Class="FlowStock.App.TsdDeviceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание аккаунта"
        Height="560" Width="900"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Аккаунты" FontWeight="SemiBold" />
            <DataGrid x:Name="DevicesGrid"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Margin="0,6,0,8"
                      SelectionChanged="DevicesGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding DeviceId}" Width="160" />
                    <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="160" />
                    <DataGridTextColumn Header="Платформа" Binding="{Binding PlatformDisplay}" Width="120" />
                    <DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}" Width="90" />
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <Button Content="Обновить" Width="120" Click="Refresh_Click" />
                <Button Content="Новый" Width="120" Margin="8,0,0,0" Click="New_Click" />
            </StackPanel>
        </Grid>
        <GroupBox Grid.Column="1" Header="Данные аккаунта" Margin="12,0,0,0">
            <DockPanel Margin="8" LastChildFill="True">
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="Сохранить" Width="140" Click="Save_Click" />
                </StackPanel>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Логин" />
                        <TextBox x:Name="LoginBox" Margin="0,2,0,8" />
                        <TextBlock Text="Пароль" />
                        <TextBox x:Name="PasswordBox" Margin="0,2,0,8" />
                        <CheckBox x:Name="IsActiveCheck" Content="Активен" Margin="0,0,0,8" />
                        <TextBlock Text="Платформа" />
                        <ComboBox x:Name="PlatformBox" Margin="0,2,0,8">
                            <ComboBoxItem Content="ТСД" Tag="TSD" />
                            <ComboBoxItem Content="ПК" Tag="PC" />
                            <ComboBoxItem Content="ПК + ТСД" Tag="BOTH" />
                        </ComboBox>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </GroupBox>
    </Grid>
</Window>
