<Window x:Class="FlowStock.App.OrderRequestsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Заявки по заказам (веб)" Height="560" Width="1080">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="ApproveButton" Content="Подтвердить" Click="Approve_Click" />
            <Button x:Name="RejectButton" Content="Отклонить" Click="Reject_Click" Margin="8,0,0,0" />
            <Button Content="Обновить" Click="Refresh_Click" Margin="8,0,0,0" />
            <CheckBox x:Name="ShowResolvedCheck" Content="Показывать обработанные" Margin="14,0,0,0"
                      VerticalAlignment="Center" Checked="ShowResolvedCheck_Changed" Unchecked="ShowResolvedCheck_Changed" />
            <Button Content="Закрыть" Click="Close_Click" Margin="8,0,0,0" />
        </StackPanel>
        <DataGrid x:Name="RequestsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Extended" SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Создан" Binding="{Binding CreatedAt, StringFormat={}{0:dd'/'MM'/'yyyy HH':'mm}}" Width="Auto" MaxWidth="170" />
                <DataGridTextColumn Header="Тип" Binding="{Binding TypeDisplay}" Width="Auto" MaxWidth="170" />
                <DataGridTextColumn Header="Запрос" Binding="{Binding Summary}" Width="*" />
                <DataGridTextColumn Header="Отправитель" Binding="{Binding RequestedBy}" Width="Auto" MaxWidth="190" />
                <DataGridTextColumn Header="Статус" Binding="{Binding StatusDisplay}" Width="Auto" MaxWidth="130" />
                <DataGridTextColumn Header="Обработан" Binding="{Binding ResolvedAt, StringFormat={}{0:dd'/'MM'/'yyyy HH':'mm}}" Width="Auto" MaxWidth="170" />
                <DataGridTextColumn Header="Комментарий" Binding="{Binding ResolutionNote}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
