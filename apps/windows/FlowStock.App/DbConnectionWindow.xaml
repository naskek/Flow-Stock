<Window x:Class="FlowStock.App.DbConnectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подключение к БД"
        Height="640" Width="640"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Текущее подключение" />
            <TextBlock x:Name="CurrentTargetText" FontWeight="SemiBold" />
        </StackPanel>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Параметры подключения">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Host" VerticalAlignment="Center" />
                        <TextBox x:Name="HostBox" Grid.Row="0" Grid.Column="1" Margin="8,0,0,6" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Port" VerticalAlignment="Center" />
                        <TextBox x:Name="PortBox" Grid.Row="1" Grid.Column="1" Margin="8,0,0,6" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Database" VerticalAlignment="Center" />
                        <TextBox x:Name="DatabaseBox" Grid.Row="2" Grid.Column="1" Margin="8,0,0,6" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Username" VerticalAlignment="Center" />
                        <TextBox x:Name="UsernameBox" Grid.Row="3" Grid.Column="1" Margin="8,0,0,6" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Password" VerticalAlignment="Center" />
                        <PasswordBox x:Name="PasswordBox" Grid.Row="4" Grid.Column="1" Margin="8,0,0,6" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Последние подключения" VerticalAlignment="Center" />
                        <ComboBox x:Name="RecentConnectionsCombo"
                                  Grid.Row="5"
                                  Grid.Column="1"
                                  Margin="8,0,0,0"
                                  DisplayMemberPath="Display"
                                  SelectionChanged="RecentConnectionsCombo_SelectionChanged" />
                    </Grid>
                </GroupBox>

                <GroupBox Header="Server API mode" Margin="0,12,0,0">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
                            <TextBlock x:Name="OrderCreateModeText" FontWeight="SemiBold" />
                            <TextBlock x:Name="OrderUpdateModeText" FontWeight="SemiBold" />
                            <TextBlock x:Name="OrderDeleteModeText" FontWeight="SemiBold" />
                            <TextBlock x:Name="OrderStatusModeText" FontWeight="SemiBold" />
                            <TextBlock x:Name="OrderApprovalModeText" FontWeight="SemiBold" />
                            <TextBlock x:Name="CreateModeText" FontWeight="SemiBold" />
                            <TextBlock x:Name="CloseModeText" FontWeight="SemiBold" />
                            <TextBlock x:Name="LineAddModeText" Margin="0,4,0,0" />
                            <TextBlock x:Name="LineUpdateModeText" Margin="0,4,0,0" />
                            <TextBlock x:Name="LineDeleteModeText" Margin="0,4,0,0" />
                            <TextBlock x:Name="ConfigLoadedText" Margin="0,4,0,0" />
                            <TextBlock x:Name="ActiveOrderCreatePathText" Margin="0,4,0,0" />
                            <TextBlock x:Name="ActiveOrderUpdatePathText" Margin="0,4,0,0" />
                            <TextBlock x:Name="ActiveOrderDeletePathText" Margin="0,4,0,0" />
                            <TextBlock x:Name="ActiveOrderStatusPathText" Margin="0,4,0,0" />
                            <TextBlock x:Name="ActiveIncomingOrderApprovalPathText" Margin="0,4,0,0" />
                            <TextBlock x:Name="ActiveCreatePathText" Margin="0,4,0,0" />
                            <TextBlock x:Name="ActiveClosePathText" Margin="0,4,0,0" />
                            <TextBlock x:Name="ActiveLineAddPathText" Margin="0,4,0,0" />
                            <TextBlock x:Name="ActiveLineUpdatePathText" Margin="0,4,0,0" />
                            <TextBlock x:Name="ActiveLineDeletePathText" Margin="0,4,0,0" />
                            <TextBlock x:Name="EnvironmentOverrideText"
                                       Margin="0,6,0,0"
                                       Foreground="DarkOrange"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed" />
                        </StackPanel>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Base URL" VerticalAlignment="Center" />
                        <TextBox x:Name="ServerBaseUrlBox" Grid.Row="1" Grid.Column="1" Margin="8,0,0,6" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Device ID" VerticalAlignment="Center" />
                        <TextBox x:Name="ServerDeviceIdBox" Grid.Row="2" Grid.Column="1" Margin="8,0,0,6" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Timeout (sec)" VerticalAlignment="Center" />
                        <TextBox x:Name="ServerTimeoutBox" Grid.Row="3" Grid.Column="1" Margin="8,0,0,6" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="TLS" VerticalAlignment="Top" />
                        <StackPanel Grid.Row="4" Grid.Column="1" Margin="8,0,0,6">
                            <CheckBox x:Name="AllowInvalidTlsCheckBox"
                                      Content="Allow invalid TLS (dev-only / unsafe)" />
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="DarkOrange"
                                       Text="Use only for local development with an untrusted certificate."
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Draft create" VerticalAlignment="Center" />
                        <CheckBox x:Name="UseServerCreateDraftCheckBox"
                                  Grid.Row="5"
                                  Grid.Column="1"
                                  Margin="8,0,0,6"
                                  Content="Use Server API for new draft creation"
                                  Checked="UseServerCreateDraftCheckBox_Changed"
                                  Unchecked="UseServerCreateDraftCheckBox_Changed" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Order create" VerticalAlignment="Center" />
                        <CheckBox x:Name="UseServerCreateOrderCheckBox"
                                  Grid.Row="6"
                                  Grid.Column="1"
                                  Margin="8,0,0,6"
                                  Content="Use Server API for order creation"
                                  Checked="UseServerCreateOrderCheckBox_Changed"
                                  Unchecked="UseServerCreateOrderCheckBox_Changed" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Order update" VerticalAlignment="Center" />
                        <CheckBox x:Name="UseServerUpdateOrderCheckBox"
                                  Grid.Row="7"
                                  Grid.Column="1"
                                  Margin="8,0,0,6"
                                  Content="Use Server API for order updates"
                                  Checked="UseServerUpdateOrderCheckBox_Changed"
                                  Unchecked="UseServerUpdateOrderCheckBox_Changed" />

                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Order status" VerticalAlignment="Center" />
                        <CheckBox x:Name="UseServerSetOrderStatusCheckBox"
                                  Grid.Row="8"
                                  Grid.Column="1"
                                  Margin="8,0,0,6"
                                  Content="Use Server API for manual order status changes"
                                  Checked="UseServerSetOrderStatusCheckBox_Changed"
                                  Unchecked="UseServerSetOrderStatusCheckBox_Changed" />

                        <TextBlock Grid.Row="9" Grid.Column="0" Text="Incoming requests" VerticalAlignment="Center" />
                        <CheckBox x:Name="UseServerIncomingOrderApprovalCheckBox"
                                  Grid.Row="9"
                                  Grid.Column="1"
                                  Margin="8,0,0,6"
                                  Content="Use Server API for order approvals in incoming requests"
                                  Checked="UseServerIncomingOrderApprovalCheckBox_Changed"
                                  Unchecked="UseServerIncomingOrderApprovalCheckBox_Changed" />

                        <TextBlock Grid.Row="10" Grid.Column="0" Text="AddLine / batch" VerticalAlignment="Center" />
                        <CheckBox x:Name="UseServerAddLineCheckBox"
                                  Grid.Row="10"
                                  Grid.Column="1"
                                  Margin="8,0,0,6"
                                  Content="Use Server API for '+ Товар' and batch line fills"
                                  Checked="UseServerAddLineCheckBox_Changed"
                                  Unchecked="UseServerAddLineCheckBox_Changed" />

                        <TextBlock Grid.Row="11" Grid.Column="0" Text="Order delete" VerticalAlignment="Center" />
                        <CheckBox x:Name="UseServerDeleteOrderCheckBox"
                                  Grid.Row="11"
                                  Grid.Column="1"
                                  Margin="8,0,0,6"
                                  Content="Use Server API for order deletion"
                                  Checked="UseServerDeleteOrderCheckBox_Changed"
                                  Unchecked="UseServerDeleteOrderCheckBox_Changed" />

                        <TextBlock Grid.Row="12" Grid.Column="0" Text="Line update" VerticalAlignment="Center" />
                        <CheckBox x:Name="UseServerUpdateLineCheckBox"
                                  Grid.Row="12"
                                  Grid.Column="1"
                                  Margin="8,0,0,6"
                                  Content="Use Server API for quantity edits of existing lines"
                                  Checked="UseServerUpdateLineCheckBox_Changed"
                                  Unchecked="UseServerUpdateLineCheckBox_Changed" />

                        <TextBlock Grid.Row="13" Grid.Column="0" Text="Line delete" VerticalAlignment="Center" />
                        <CheckBox x:Name="UseServerDeleteLineCheckBox"
                                  Grid.Row="13"
                                  Grid.Column="1"
                                  Margin="8,0,0,6"
                                  Content="Use Server API for deleting existing lines"
                                  Checked="UseServerDeleteLineCheckBox_Changed"
                                  Unchecked="UseServerDeleteLineCheckBox_Changed" />

                        <StackPanel Grid.Row="14"
                                    Grid.ColumnSpan="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0,8,0,0">
                            <Button x:Name="ToggleCloseModeButton"
                                    Width="150"
                                    Click="ToggleCloseMode_Click" />
                            <Button Content="Check server"
                                    Width="110"
                                    Margin="8,0,0,0"
                                    Click="CheckServer_Click" />
                            <Button Content="Save"
                                    Width="100"
                                    Margin="8,0,0,0"
                                    Click="SaveServerSettings_Click" />
                        </StackPanel>

                        <TextBlock x:Name="ServerStatusText"
                                   Grid.Row="15"
                                   Grid.ColumnSpan="2"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap" />
                    </Grid>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Тест подключения" Width="120" Click="TestConnection_Click" />
            <Button Content="Подключиться" Width="120" Margin="8,0,0,0" Click="Save_Click" />
            <Button Content="Закрыть" Width="120" Margin="8,0,0,0" IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
